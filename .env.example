# ── Supabase ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Auth ──────────────────────────────────────────────────────────────
# Public URL of this app — used by the auth callback to build email-verify
# and password-reset redirect URLs. In prod set to https://guestlistsocial.com.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Turnstile (optional bot protection on auth forms) ─────────────────
# If unset, Turnstile is skipped entirely. Set both in prod to enforce.
# TURNSTILE_SECRET_KEY=
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ── Meta Graph API (for ad sync + decision execution) ────────────────
META_ACCESS_TOKEN=EAAx...
META_AD_ACCOUNT_ID=act_123456789

# ── Meta Social Publishing (OAuth flow for connected accounts) ───────
META_SOCIAL_APP_ID=123456789
META_SOCIAL_APP_SECRET=abc...
META_SOCIAL_REDIRECT_URI=https://yourdomain.com/api/meta/callback

# ── Anthropic (decision engine, reviews, playbooks) ──────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Interactions (Instagram comment feed) ────────────────────────────
# Option A: Apify actor output URL
# Option B: your own /comments proxy endpoint
INTERACTION_IG_SOURCE_URL=https://your-proxy.example.com/comments
INTERACTION_IG_SOURCE_AUTH_HEADER=Bearer your-token
# Comma-separated keywords to highlight in comments
INTERACTION_IG_KEYWORDS=zanzibar,kendwa,nungwi,restaurant,lunch,dinner,smoothie,food

# ── Email (optional — for sending review digests to clients) ─────────
# SMTP_HOST=smtp.provider.com
# SMTP_PORT=587
# SMTP_USER=you@provider.com
# SMTP_PASS=secret
# SMTP_FROM=noreply@yourdomain.com
